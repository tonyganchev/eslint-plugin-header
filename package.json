{
  "name": "@tony.ganchev/eslint-plugin-header",
  "version": "3.4.4",
  "description": "The native ESLint 9/10 header plugin. A zero-bloat, drop-in replacement for 'eslint-plugin-header' with first-class Flat Config & TypeScript support. Auto-fix Copyright, License, and banner comments in JavaScript, TypeScript, Vue, Svelte, CSS, HTML, YAML, and Markdown files. Supports oxlint.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "files": [
    "lib/**/*.js",
    "index.d.ts*",
    "types",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "e2e": "pnpm build && mocha --timeout 60000 tests/e2e/*.js",
    "eslint": "eslint .",
    "lint": "pnpm eslint && pnpm markdownlint",
    "markdownlint": "markdownlint *.md docs/**/*.md",
    "test": "pnpm lint && pnpm unit && pnpm e2e",
    "unit": "mcr -c .mcr.config.js mocha tests/lib/*.js tests/lib/**/*.js"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@html-eslint/eslint-plugin": "^0.62.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/estree": "^1.0.9",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "eslint-plugin-jsdoc": "^63.0.6",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-svelte": "^3.19.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.4.0",
    "globals": "^17.6.0",
    "markdownlint-cli": "^0.49.0",
    "mocha": "12.0.0-alpha-issue-5899.4",
    "monocart-coverage-reports": "^2.12.12",
    "svelte": "^5.56.3",
    "svelte-eslint-parser": "^1.8.0",
    "testdouble": "^3.20.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vue-eslint-parser": "^10.4.1"
  },
  "peerDependencies": {
    "eslint": ">=7.7.0"
  },
  "packageManager": "pnpm@11.8.0",
  "keywords": [
    "autofix",
    "auto-fix",
    "banner",
    "check",
    "copyright",
    "copyright-header",
    "css",
    "eslint",
    "eslint9",
    "eslint10",
    "eslintcss",
    "eslintplugin",
    "eslintscss",
    "eslint-css",
    "eslint-plugin",
    "eslint-scss",
    "fix",
    "flat-config",
    "header",
    "html",
    "license",
    "license-header",
    "linter",
    "legal",
    "markdown",
    "md",
    "notice",
    "oxlint",
    "oxc",
    "react",
    "source-header",
    "svelte",
    "sveltejs",
    "svelte-js",
    "typescript",
    "vue",
    "vuejs",
    "vue-js",
    "yaml",
    "yml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tonyganchev/eslint-plugin-header.git"
  },
  "homepage": "https://github.com/tonyganchev/eslint-plugin-header#readme",
  "bugs": {
    "url": "https://github.com/tonyganchev/eslint-plugin-header/issues"
  },
  "license": "MIT",
  "author": "Tony Ganchev",
  "maintainers": [
    "Gyokan Syuleymanov",
    "Tony Ganchev"
  ],
  "contributors": [
    "Josh Kelley",
    "Stuart Knightley"
  ]
}