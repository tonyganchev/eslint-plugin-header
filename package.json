{
  "name": "@tony.ganchev/eslint-plugin-header",
  "version": "3.3.4",
  "description": "The native ESLint 9/10 header plugin. A zero-bloat, drop-in replacement for 'eslint-plugin-header' with first-class Flat Config & TypeScript support. Auto-fix Copyright, License, and banner comments in JavaScrip, TypeScript, CSS, and Markdown files. Supports oxlint.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "files": [
    "lib/**/*.js",
    "index.d.ts*",
    "types",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "e2e": "pnpm build && mocha --timeout 60000 tests/e2e/*.js",
    "eslint": "eslint .",
    "lint": "pnpm eslint && pnpm markdownlint",
    "markdownlint": "markdownlint *.md docs/**/*.md",
    "test": "pnpm lint && pnpm unit && pnpm e2e",
    "unit": "c8 --reporter=html --reporter=text --reporter=text-summary --reporter=lcov --check-coverage --100 mocha tests/lib/*.js tests/lib/**/*.js"
  },
  "devDependencies": {
    "@eslint/core": "^1.1.1",
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "markdownlint-cli": "^0.48.0",
    "mocha": "12.0.0-beta-10",
    "testdouble": "^3.20.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "peerDependencies": {
    "eslint": ">=7.7.0"
  },
  "packageManager": "pnpm@10.32.1",
  "keywords": [
    "autofix",
    "auto-fix",
    "banner",
    "check",
    "copyright",
    "copyright-header",
    "css",
    "eslint",
    "eslint9",
    "eslint10",
    "eslintcss",
    "eslintplugin",
    "eslintscss",
    "eslint-css",
    "eslint-plugin",
    "eslint-scss",
    "fix",
    "flat-config",
    "header",
    "license",
    "license-header",
    "linter",
    "legal",
    "markdown",
    "md",
    "notice",
    "oxlint",
    "oxc",
    "react",
    "source-header",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tonyganchev/eslint-plugin-header.git"
  },
  "homepage": "https://github.com/tonyganchev/eslint-plugin-header#readme",
  "bugs": {
    "url": "https://github.com/tonyganchev/eslint-plugin-header/issues"
  },
  "license": "MIT",
  "author": "Tony Ganchev",
  "maintainers": [
    "Gyokan Syuleymanov",
    "Tony Ganchev"
  ],
  "contributors": [
    "Josh Kelley",
    "Stuart Knightley"
  ]
}